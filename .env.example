# Firebase Configuration
FIREBASE_PROJECT_ID=project-404e35e2-6a5d-421b-970
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@project-404e35e2-6a5d-421b-970.iam.gserviceaccount.com

# Environment
NODE_ENV=production
PORT=3000

# Auth hardening
# In production this should stay true to protect admin/driver/customer sensitive endpoints.
AUTH_ENFORCE_ROLES=true
# Development-only header auth fallback (X-Karryt-Role/X-Karryt-User-Id)
AUTH_ALLOW_DEV_HEADERS=false
# Optional shared key for development header auth. If set, requests must send X-Karryt-Auth-Key.
AUTH_DEV_SHARED_KEY=

# Google Maps API keys for exact address validation and geocoding
# Use a billing-enabled Google Maps Platform project with Address Validation API,
# Places API and Geocoding API enabled.
GOOGLE_PLACES_API_KEY=your_google_places_api_key
GOOGLE_ADDRESS_VALIDATION_API_KEY=your_google_address_validation_api_key
