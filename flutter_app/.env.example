# Google Cloud API Keys (PRIMARY - Required for best experience)
# Get GOOGLE_PLACES_API_KEY from: https://console.cloud.google.com/
# - Enable APIs: Places API, Geocoding API
# - Create API key with HTTP referrer restrictions (localhost:62061, etc)
GOOGLE_PLACES_API_KEY=sk-your_google_places_api_key_here

# Optional but recommended for exact street-number validation
# - Enable API: Address Validation API
GOOGLE_ADDRESS_VALIDATION_API_KEY=sk-your_google_address_validation_api_key_here

# Optional for route confirmation only (used on: Recalcular tarifa y Solicitar)
# - Enable API: Routes API
# - Not used while the user is typing addresses
GOOGLE_ROUTES_API_KEY=sk-your_google_routes_api_key_here

# Mapbox Access Token (OPTIONAL - Used as fallback provider)
# Get from: https://account.mapbox.com/tokens/
# Only needed if Google APIs unavailable or as backup
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# Firebase Cloud Messaging (Web)
# Required for browser push token generation (vapidKey in getToken)
FIREBASE_WEB_VAPID_KEY=your_web_push_certificate_key_pair

# Firebase Push Notifications (Mobile — Android / iOS)
# Requerido para que firebase_messaging funcione en builds móviles sin google-services.json.
# Si tienes google-services.json y GoogleService-Info.plist en las carpetas de la plataforma,
# estas variables son opcionales (el build de Gradle/Xcode las lee del JSON/plist).
# Obtenlos en: https://console.firebase.google.com/ > Configuración del proyecto
#
# FIREBASE_PROJECT_ID        → Configuración general > ID del proyecto
# FIREBASE_API_KEY           → Configuración general > Clave de API web (o clave de Android/iOS)
# FIREBASE_APP_ID            → Tus apps > ID de la app (ej: 1:123456:android:abcdef)
# FIREBASE_MESSAGING_SENDER_ID → Configuración general > Número de proyecto
# FIREBASE_STORAGE_BUCKET    → Configuración general > Cloud Storage (opcional)
# FIREBASE_AUTH_DOMAIN       → Solo web: <project-id>.firebaseapp.com (opcional)
#
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=AIzaSy-your-firebase-api-key
FIREBASE_APP_ID=1:000000000000:android:aaaaaaaaaaaaaaaa
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
